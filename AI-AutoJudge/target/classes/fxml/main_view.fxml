<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.autojudge.controller.MainController"
            prefWidth="1200" prefHeight="750"
            styleClass="root-pane">

    <!-- ===== NAVBAR ===== -->
    <top>
        <HBox styleClass="navbar" alignment="CENTER_LEFT" spacing="12">
            <padding><Insets top="13" right="20" bottom="13" left="20"/></padding>
            <Label text="⚡" styleClass="navbar-icon"/>
            <Label text="AI Auto Judge" styleClass="navbar-title"/>
            <Label text="VNOJ Style" styleClass="navbar-badge"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="v1.0.0" styleClass="navbar-version"/>
        </HBox>
    </top>

    <!-- ===== MAIN CONTENT ===== -->
    <center>
        <SplitPane dividerPositions="0.42" styleClass="main-split">
            <items>

                <!-- ===== LEFT PANEL: Đề Bài ===== -->
                <VBox styleClass="side-panel" spacing="0">
                    <padding><Insets top="0" right="0" bottom="0" left="0"/></padding>

                    <!-- Panel Header -->
                    <HBox styleClass="panel-header" alignment="CENTER_LEFT" spacing="8">
                        <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
                        <Label text="📋" styleClass="panel-header-icon"/>
                        <Label text="Đề Bài" styleClass="panel-header-title"/>
                    </HBox>

                    <VBox spacing="10" VBox.vgrow="ALWAYS">
                        <padding><Insets top="12" right="14" bottom="10" left="14"/></padding>

                        <TextArea fx:id="problemDescriptionArea"
                                  promptText="Nhập nội dung đề bài tại đây, hoặc tải ảnh đề bài lên..."
                                  wrapText="true"
                                  VBox.vgrow="ALWAYS"
                                  styleClass="problem-area"/>

                        <HBox spacing="8">
                            <Button fx:id="btnUploadImage"
                                    text="📎  Tải ảnh đề"
                                    styleClass="btn-outline"
                                    prefHeight="36"/>
                            <Button fx:id="btnAnalyze"
                                    text="🤖  Phân tích &amp; Sinh Testcase"
                                    styleClass="btn-primary"
                                    HBox.hgrow="ALWAYS"
                                    maxWidth="Infinity"
                                    prefHeight="36"/>
                        </HBox>
                    </VBox>

                    <!-- Divider line -->
                    <Separator styleClass="divider-line"/>

                    <!-- System Log -->
                    <VBox spacing="6">
                        <padding><Insets top="10" right="14" bottom="12" left="14"/></padding>
                        <HBox alignment="CENTER_LEFT" spacing="6">
                            <Label text="📊" styleClass="section-icon"/>
                            <Label text="Nhật ký hệ thống" styleClass="section-title"/>
                        </HBox>
                        <TextArea fx:id="systemLogArea"
                                  editable="false"
                                  prefHeight="140"
                                  wrapText="true"
                                  styleClass="log-area"/>
                    </VBox>
                </VBox>

                <!-- ===== RIGHT PANEL: Code Editor + Results ===== -->
                <VBox styleClass="side-panel" spacing="0">

                    <!-- Editor Header -->
                    <HBox styleClass="editor-header" alignment="CENTER_LEFT" spacing="10">
                        <padding><Insets top="10" right="14" bottom="10" left="16"/></padding>
                        <Label text="💻" styleClass="panel-header-icon"/>
                        <Label text="Code Editor" styleClass="panel-header-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="Ngôn ngữ:" styleClass="label-muted"/>
                        <ComboBox fx:id="cbLanguage" prefWidth="110" styleClass="lang-combo"/>
                        <Button fx:id="btnSubmit"
                                text="▶  Nộp bài"
                                styleClass="btn-submit"
                                prefHeight="36"/>
                    </HBox>

                    <!-- Code TextArea -->
                    <VBox VBox.vgrow="ALWAYS">
                        <padding><Insets top="0" right="14" bottom="10" left="14"/></padding>
                        <TextArea fx:id="codeEditorArea"
                                  promptText="// Viết code của bạn ở đây..."
                                  VBox.vgrow="ALWAYS"
                                  styleClass="code-editor"/>
                    </VBox>

                    <!-- Divider -->
                    <Separator styleClass="divider-line"/>

                    <!-- Results Section -->
                    <VBox spacing="8">
                        <padding><Insets top="10" right="14" bottom="12" left="14"/></padding>

                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label text="📈" styleClass="section-icon"/>
                            <Label text="Kết quả chấm" styleClass="section-title"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="scoreLabel" text="" styleClass="score-label"/>
                        </HBox>

                        <TableView fx:id="resultTable" prefHeight="215" styleClass="result-table">
                            <columns>
                                <TableColumn fx:id="colId"       text="Test #"        prefWidth="58"  minWidth="55"/>
                                <TableColumn fx:id="colStatus"   text="Trạng thái"    prefWidth="155" minWidth="140"/>
                                <TableColumn fx:id="colTime"     text="Thời gian"     prefWidth="95"  minWidth="85"/>
                                <TableColumn fx:id="colInput"    text="Input"         prefWidth="130" minWidth="100"/>
                                <TableColumn fx:id="colExpected" text="Expected"      prefWidth="130" minWidth="100"/>
                                <TableColumn fx:id="colOutput"   text="Output của bạn" prefWidth="160" minWidth="130"/>
                            </columns>
                            <placeholder>
                                <Label text="Chưa có kết quả — hãy phân tích đề và nộp bài!" styleClass="table-placeholder"/>
                            </placeholder>
                        </TableView>
                    </VBox>
                </VBox>

            </items>
        </SplitPane>
    </center>
</BorderPane>