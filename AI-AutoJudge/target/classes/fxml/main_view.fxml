<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<SplitPane dividerPositions="0.4" prefHeight="700.0" prefWidth="1100.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.autojudge.controller.MainController">
    <items>
        <!-- BÊN TRÁI: Khu vực nhập đề và phân tích AI -->
        <VBox spacing="10.0">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
            <Label style="-fx-font-weight: bold; -fx-font-size: 14;" text="1. Nhập đề bài (Text hoặc Upload Ảnh)" />
            <TextArea fx:id="problemDescriptionArea" prefHeight="400.0" promptText="Nhập nội dung đề bài tại đây..." wrapText="true" VBox.vgrow="ALWAYS" />
            
            <HBox spacing="10.0">
                <Button fx:id="btnUploadImage" text="Tải ảnh đề lên..." />
                <Button fx:id="btnAnalyze" style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-weight: bold;" text="Phân tích đề &amp; Sinh Testcase" />
            </HBox>
            
            <Label text="Trạng thái hệ thống:" />
            <TextArea fx:id="systemLogArea" editable="false" prefHeight="150.0" style="-fx-control-inner-background: #f4f4f4;" wrapText="true" />
        </VBox>

        <!-- BÊN PHẢI: Khu vực Code và Chấm bài -->
        <VBox spacing="10.0">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Label style="-fx-font-weight: bold; -fx-font-size: 14;" text="2. Soạn thảo Code:" />
                <ComboBox fx:id="cbLanguage" prefWidth="120.0" />
            </HBox>
            <TextArea fx:id="codeEditorArea" prefHeight="400.0" promptText="Viết code của bạn ở đây..." style="-fx-font-family: 'Consolas', monospace;" VBox.vgrow="ALWAYS" />
            
            <HBox alignment="CENTER_RIGHT" spacing="10.0">
                <Button fx:id="btnSubmit" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold;" text="Submit Code" />
            </HBox>
            
            <Label text="Kết quả chấm (Judge Results):" />
            <!-- Hiển thị kết quả bằng TableView hoặc TextArea tùy chọn, tạm thời dùng TextArea cho đơn giản -->
            <TextArea fx:id="resultArea" editable="false" prefHeight="150.0" style="-fx-control-inner-background: #000000; -fx-text-fill: #00FF00; -fx-font-family: 'Consolas', monospace;" />
        </VBox>
    </items>
</SplitPane>